{"componentChunkName": "component---src-templates-boattemplate-jsx", "path": "/boat/117", "result": {"pageContext": {"absolute": "https://oga.org.uk", "boat": {"builder": [{"id": "54a8f02f-5a74-4c6d-a51d-8cb86e86db67", "name": "Hugh McClean Sons/P J Parsons"}], "construction_material": "wood", "created_at": "2020-04-25T16:44:11.280203+00:00", "full_description": "<p>Built in 1925 at Barrow-in-Furness as a lifeboat for the S.S. <em>Otranto</em>.</p>\n<p>Peter and John Parsons, converted <em>Chlamys</em> into a gaff rigged yacht in the late\n50\u2019s on the river Hamble near \u00a0Burseldon boatyard. They had considerable success\nin the East Coast \u00a0Gaffers races in the late 60\u2019s and the early 70\u2019s, and also\nused her for cruising on the East Coast and the Medway.</p>", "handicap_data": {"beam": 3.048, "draft": 1.28, "length_on_deck": 10.546, "length_on_waterline": 9.754, "length_over_all": 10.546}, "home_port": "London", "id": "a8b8d598-4ccb-4428-bfbb-9fd1eac8f6ce", "image_key": "DpDnNs", "lastModified": "2023-01-02T20:28:44Z", "mainsail_type": "gaff", "name": "Chlamys", "oga_no": 117, "ownerships": [{"name": "Simon William Godwin", "share": 64, "start": 1998}], "place_built": "Renfrew/Welling", "rig_type": "Cutter", "selling_status": "not_for_sale", "short_description": "<p><em>Chlamys</em> is a converted ship's lifeboat.</p>", "spar_material": "wood", "updated_at": "2026-06-22", "year": 1925, "year_is_approximate": false, "year_of_build": {"value": 1925}}, "home": "/", "pathSlug": "/boat/117"}}, "staticQueryHashes": []}